<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/dialog_background"
    android:paddingHorizontal="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#DDDDDD"
        android:layout_marginBottom="20dp" />

    <!-- Success circle -->
    <androidx.cardview.widget.CardView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="@color/blue_primary"
        app:cardCornerRadius="50dp"
        app:cardElevation="6dp">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check"
            app:tint="@android:color/white"
            android:contentDescription="Success" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Booking Confirmed!"
        android:textColor="#1A1A1A"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your service has been booked successfully"
        android:textColor="#777777"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- ✅ Download Health Report (Pro only) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDownloadReport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="📄 Download Health Report (PDF)"
        android:textColor="@color/blue_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="14dp"
        app:strokeColor="@color/blue_primary"
        app:strokeWidth="2dp"
        android:padding="14dp" />

    <!-- Done Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDoneBooking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Done"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/blue_primary"
        app:cornerRadius="14dp"
        android:padding="16dp" />

</LinearLayout>