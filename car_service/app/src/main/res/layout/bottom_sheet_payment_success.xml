<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/dialog_background"
    android:paddingHorizontal="28dp"
    android:paddingTop="16dp"
    android:paddingBottom="40dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#DDDDDD"
        android:layout_marginBottom="28dp" />

    <!-- Success circle -->
    <androidx.cardview.widget.CardView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="@color/blue_primary"
        app:cardCornerRadius="50dp"
        app:cardElevation="8dp">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check"
            app:tint="@android:color/white"
            android:contentDescription="Success" />
    </androidx.cardview.widget.CardView>

    <!-- Pro badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/pro_badge_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐  PRO MEMBER"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Successful!"
        android:textColor="#1A1A1A"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to AutoMate Pro.\nYour account has been upgraded."
        android:textColor="#666666"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AED 39 charged"
        android:textColor="@color/blue_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="28dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginBottom="20dp" />

    <!-- What's unlocked -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You now have access to:"
        android:textColor="#888888"
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📸  Camera Warning Light Scanner"
            android:textColor="#333333" android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📄  Digital Vehicle Health Reports"
            android:textColor="#333333" android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📥  Booking History Export PDF"
            android:textColor="#333333" android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🔔  Service Reminder AI"
            android:textColor="#333333" android:textSize="14sp" />
    </LinearLayout>

    <!-- Go to Home button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnGoHome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/blue_primary"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Using Pro Features →"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp" />
    </androidx.cardview.widget.CardView>

</LinearLayout>