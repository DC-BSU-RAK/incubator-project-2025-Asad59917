<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:paddingHorizontal="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#DDDDDD"
        android:layout_marginBottom="20dp" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐"
            android:textSize="40sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upgrade to Pro"
            android:textColor="#1A1A1A"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unlock AutoScan AI + premium features"
            android:textColor="#777777"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Features list -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F8F9FF"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="20dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📸  Camera Warning Light Scanner" android:textColor="#333333"
            android:textSize="14sp" android:layout_marginBottom="8dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📄  Digital Vehicle Health Report PDF" android:textColor="#333333"
            android:textSize="14sp" android:layout_marginBottom="8dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📥  Booking History Export" android:textColor="#333333"
            android:textSize="14sp" android:layout_marginBottom="8dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🔔  Service Reminder AI" android:textColor="#333333"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Pro Plan Button (only one plan) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/upgradeProButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/premium_banner_gradient"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AutoMate Pro"
                    android:textColor="@android:color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All premium features included"
                    android:textColor="#CCE0FF"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AED 39"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="per month"
                    android:textColor="#CCE0FF"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Continue hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap the plan above to continue to payment"
        android:textColor="#999999"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Maybe Later -->
    <TextView
        android:id="@+id/maybeLaterButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Maybe Later"
        android:textColor="#999999"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="8dp" />

</LinearLayout>